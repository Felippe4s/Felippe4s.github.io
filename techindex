<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XTRATTO - Agência de Marketing Estratégico Político</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: #1a1a1a;
            background: #ffffff;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* HEADER & NAVEGAÇÃO */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(10, 10, 10, 0.98);
            backdrop-filter: blur(10px);
            z-index: 1000;
            padding: 1.2rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        }

        .logo {
            font-size: 1.6rem;
            font-weight: 800;
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 2px;
            font-family: 'Poppins', sans-serif;
        }

        nav {
            display: flex;
            gap: 2.5rem;
            align-items: center;
        }

        nav a {
            color: #ffffff;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            transition: color 0.3s ease;
        }

        nav a:hover {
            color: #d4af37;
        }

        .cta-header {
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            color: #000;
            padding: 0.7rem 1.8rem;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            font-size: 0.95rem;
        }

        .cta-header:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            color: #d4af37;
            font-size: 1.8rem;
            cursor: pointer;
        }

        /* HERO SECTION */
        .hero {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
            color: #ffffff;
            padding: 150px 5% 100px;
            text-align: center;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
                        radial-gradient(circle at 80% 50%, rgba(212, 175, 55, 0.05) 0%, transparent 50%);
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            max-width: 900px;
        }

        .logo-hero {
            width: 140px;
            height: 140px;
            margin: 0 auto 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(212, 175, 55, 0.1);
            border-radius: 25px;
            font-size: 4.5rem;
            font-weight: 800;
            color: #d4af37;
            font-family: 'Poppins', sans-serif;
            box-shadow: 0 20px 50px rgba(212, 175, 55, 0.15);
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }

        h1 {
            font-size: 4.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            font-family: 'Poppins', sans-serif;
            line-height: 1.1;
            background: linear-gradient(135deg, #ffffff 0%, #d4af37 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            font-size: 1.4rem;
            color: #b0b0b0;
            margin-bottom: 2.5rem;
            font-weight: 400;
            letter-spacing: 0.5px;
        }

        .hero-buttons {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            color: #000;
            padding: 1.1rem 2.8rem;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(212, 175, 55, 0.4);
        }

        .btn-secondary {
            background: transparent;
            color: #d4af37;
            padding: 1.1rem 2.8rem;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            border: 2px solid #d4af37;
            transition: all 0.3s ease;
        }

        .btn-secondary:hover {
            background: #d4af37;
            color: #000;
        }

        /* ABOUT SECTION */
        .about {
            padding: 100px 5%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-header h2 {
            font-size: 3rem;
            font-weight: 800;
            font-family: 'Poppins', sans-serif;
            margin-bottom: 1rem;
            color: #0a0a0a;
        }

        .section-header p {
            font-size: 1.2rem;
            color: #666;
            max-width: 600px;
            margin: 0 auto;
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .about-text h3 {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: #0a0a0a;
        }

        .about-text p {
            font-size: 1rem;
            color: #555;
            margin-bottom: 1.5rem;
            line-height: 1.8;
        }

        .about-image {
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            height: 400px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 8rem;
            color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 20px 50px rgba(212, 175, 55, 0.2);
        }

        /* SOLUTIONS SECTION */
        .solutions {
            padding: 100px 5%;
            background: #f8f8f8;
        }

        .solutions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .solution-card {
            background: #ffffff;
            padding: 2.5rem;
            border-radius: 16px;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            border: 2px solid transparent;
        }

        .solution-card:hover {
            border-color: #d4af37;
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(212, 175, 55, 0.15);
        }

        .solution-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.5rem;
            box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
        }

        .solution-card h3 {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #0a0a0a;
        }

        .solution-card p {
            color: #666;
            font-size: 0.95rem;
            line-height: 1.6;
        }

        /* PORTFOLIO SECTION */
        .portfolio {
            padding: 100px 5%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .portfolio-item {
            background: #f0f0f0;
            border-radius: 16px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        }

        .portfolio-item:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 40px rgba(212, 175, 55, 0.2);
        }

        .portfolio-image {
            width: 100%;
            height: 250px;
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: rgba(255, 255, 255, 0.2);
        }

        .portfolio-info {
            padding: 1.5rem;
        }

        .portfolio-info h4 {
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: #0a0a0a;
        }

        .portfolio-info p {
            font-size: 0.9rem;
            color: #999;
        }

        /* PRICING SECTION */
        .pricing {
            padding: 100px 5%;
            background: #f8f8f8;
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .pricing-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 2.5rem;
            text-align: center;
            position: relative;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            border: 2px solid #e0e0e0;
        }

        .pricing-card:hover {
            border-color: #d4af37;
            transform: translateY(-10px);
            box-shadow: 0 20px 50px rgba(212, 175, 55, 0.2);
        }

        .pricing-card.featured {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
            color: #ffffff;
            border-color: #d4af37;
            transform: scale(1.05);
        }

        .pricing-card.featured:hover {
            transform: scale(1.05) translateY(-10px);
        }

        .pricing-card.featured .badge {
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            color: #000;
            padding: 0.5rem 1.5rem;
            border-radius: 25px;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .pricing-card h3 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            font-family: 'Poppins', sans-serif;
        }

        .price {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #d4af37;
        }

        .price-subtitle {
            font-size: 0.9rem;
            margin-bottom: 2rem;
            opacity: 0.8;
        }

        .pricing-card.featured .price-subtitle {
            color: #b0b0b0;
        }

        .features-list {
            text-align: left;
            margin-bottom: 2rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            font-size: 0.95rem;
        }

        .feature-check {
            width: 20px;
            height: 20px;
            background: #d4af37;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-weight: bold;
            flex-shrink: 0;
            font-size: 0.75rem;
        }

        .pricing-button {
            width: 100%;
            padding: 1rem;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
        }

        .pricing-button.light {
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            color: #000;
        }

        .pricing-button.light:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
        }

        .pricing-button.dark {
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            color: #000;
        }

        .pricing-button.dark:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
        }

        /* CONTACT SECTION */
        .contact {
            padding: 100px 5%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .contact-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: flex-start;
        }

        .contact-info h3 {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: #0a0a0a;
        }

        .contact-info p {
            font-size: 1rem;
            color: #555;
            margin-bottom: 2rem;
            line-height: 1.8;
        }

        .contact-details {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .detail-item {
            display: flex;
            gap: 1.5rem;
            align-items: flex-start;
        }

        .detail-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #d4af37 0%, #e6c547 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .detail-content h4 {
            font-weight: 700;
            margin-bottom: 0.3rem;
            color: #0a0a0a;
        }

        .detail-content p {
            font-size: 0.95rem;
            color: #666;
            margin: 0;
        }

        .form-container {
            background: #ffffff;
